<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.bignerdranch.playlistmaker.media.playlist.SinglePlaylistFragment">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colors_FFFFFFFF_1A1B22"

        android:backgroundTint="@color/color_E6E8EB"
        android:paddingStart="@dimen/dimen16"
        android:paddingTop="@dimen/dimen14"
        android:paddingEnd="@dimen/dimen16">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.6" />



        <ImageView
            android:id="@+id/arrow_back"
            style="@style/arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/ripple_circle"/>

        <ImageView
            android:id="@+id/playlistCover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="39dp"
            android:layout_marginBottom="@dimen/dimen24"

            android:scaleType="centerCrop"
            app:layout_constraintBottom_toTopOf="@+id/playlistName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/arrow_back"

            tools:src="@drawable/placeholder" />

        <TextView
            android:id="@+id/playlistName"
            style="@style/YS_Medium_22"
            android:textSize="24sp"
            app:layout_constraintBottom_toTopOf="@+id/playlistDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/playlistCover"


            tools:text="Еее бой" />

        <TextView
            android:id="@+id/playlistDescription"
            style="@style/YS_Regular_13"
            android:layout_marginTop="8dp"
            android:textColor="@color/colors_FF000000_FFFFFFFF"
            android:textSize="18sp"
            app:layout_constraintBottom_toTopOf="@+id/songsDuration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/playlistName"
            tools:text="Описание альбома" />

        <TextView
            android:id="@+id/songsDuration"
            style="@style/YS_Regular_13"
            android:layout_marginTop="8dp"
            android:textColor="@color/colors_FF000000_FFFFFFFF"
            android:textSize="18sp"
            app:layout_constraintBottom_toTopOf="@+id/playlistShare"
            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toBottomOf="@+id/playlistDescription"
            tools:text="XXX минут" />

        <ImageView
            android:id="@+id/playlistDot"
            style="@style/text_track_view"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:src="@drawable/ellipse_song_search"
            app:layout_constraintBottom_toBottomOf="@+id/songsDuration"
            app:layout_constraintStart_toEndOf="@+id/songsDuration"
            app:layout_constraintTop_toTopOf="@+id/songsDuration"

            app:tint="@color/color_1A1B22" />

        <TextView
            android:id="@+id/songsNumber"
            style="@style/YS_Regular_13"
            android:layout_marginStart="5dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/colors_FF000000_FFFFFFFF"
            android:textSize="18sp"
            app:layout_constraintBaseline_toBaselineOf="@+id/songsDuration"
            app:layout_constraintStart_toEndOf="@+id/playlistDot"

            tools:text="100 песен" />

        <ImageView
            android:id="@+id/playlistShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:layout_marginBottom="27dp"
            android:src="@drawable/share"
            app:layout_constraintBottom_toTopOf="@+id/guideLine"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/songsDuration"
            app:tint="@color/color_1A1B22" />

        <ImageView
            android:id="@+id/threeDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="26dp"
            android:src="@drawable/three_dots"


            app:layout_constraintBottom_toBottomOf="@+id/playlistShare"
            app:layout_constraintStart_toEndOf="@+id/playlistShare"
            app:layout_constraintTop_toTopOf="@+id/playlistShare"
            app:tint="@color/color_1A1B22"

            />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Sheet для плейлистов -->
    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="gone" />


    <LinearLayout
        android:id="@+id/bottom_sheet_playlists"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/sheet_bottom"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"

        app:behavior_fitToContents="false"
        app:behavior_hideable="false"
        app:behavior_peekHeight="0dp"

        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:id="@+id/bottom_sheet_handle"
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="30dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/sheet_tap_shape"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <TextView
            style="@style/text_search_error"
            android:layout_width="match_parent"

            android:layout_marginTop="0dp"
            android:gravity="center"
            android:text="@string/addToPlaylist" />

        <Button
            android:id="@+id/newPlaylistButton"
            style="@style/button_for_updateButton_and_clearSearchList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"
            android:text="@string/new_playlist" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlistInSheetRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:listitem="@layout/item_track"
            tools:itemCount="3"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>