<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/search_song_box_height"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/playlistCover"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center_vertical"
        tools:background="@color/color_3772E7_3772E7"
        android:src="@drawable/placeholder"  />

    <LinearLayout
        style="@style/text_track_view"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/playlistName"
            style="@style/text_track_view"
            android:layout_width="wrap_content"
            android:textColor="@color/colors_FF000000_FFFFFFFF"
            android:textSize="@dimen/sp16"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Название песни --- Очень длинное прям ужас как" />

        <TextView
            android:id="@+id/playlistTrackCount"
            style="@style/text_track_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"

            android:maxLines="1"
            android:textColor="@color/color_AEAFB4_FFFFFFFF"
            android:textSize="@dimen/text_group_name_and_duration"
            tools:text="Количество треков : 12" />

    </LinearLayout>

</LinearLayout>
