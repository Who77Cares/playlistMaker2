<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="buttonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_main_height</item>
        <item name="android:layout_weight">1</item>
        <item name="android:backgroundTint">@color/color_white</item>
        <item name="android:textSize">@dimen/sp22</item>
        <item name="android:textColor">@color/main_text_buttons</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="iconGravity">textStart</item>
        <item name="iconSize">25dp</item>
        <item name="iconTint">@color/main_button_tint</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="imageView_settingsLayout" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">right</item>
        <item name="tint">@color/settings_add_icons</item>
    </style>

    <style name="linearLayout_settingsLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_gravity">center_vertical</item>
    </style>

    <style name="text_settings_style" >
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/settings_text_options</item>
        <item name="android:textSize">@dimen/sp16</item>
        <item name="android:paddingVertical">@dimen/sp16</item>
    </style>

    <style name="text_track_view" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="fontFamily">@font/ys_display_regular</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="text_search_error" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:textColor">@color/text_error_color</item>
        <item name="fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">19sp</item>
        <item name="android:layout_marginTop">@dimen/dimen12</item>
    </style>


    <style name="Widget.MyTabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabTextColor">@color/text_error_color</item>
        <item name="tabSelectedTextColor">@color/text_error_color</item>
        <item name="tabIndicatorColor">@color/text_error_color</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="android:background">@color/background_color</item>

        <item name="tabMode">fixed</item>
        <item name="tabGravity">fill</item>
    </style>


    <style name="linear_layout_for_search" >
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginTop">32dp</item>
        <item name="android:layout_marginBottom">32dp</item>
    </style>

    <style name="button_for_updateButton_and_clearSearchList" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/dimen24</item>
        <item name="backgroundTint">@color/text_error_color</item>
        <item name="android:textColor">@color/background_color</item>
        <item name="cornerRadius">54dp</item>
    </style>


    <style name="arrow_back" >
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="tint">@color/settings_back_icon</item>
        <item name="android:src">@drawable/arrow_back</item>
    </style>

    <!-- Текст-->

    <style name="YS_Medium_22" >
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/main_text</item>
        <item name="android:textSize">@dimen/sp22</item>
    </style>

    <style name="YS_Medium_14" >
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/main_text</item>
        <item name="android:textSize">@dimen/sp14</item>
    </style>

    <style name="YS_Regular_13" >
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#AEAFB4</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="YS_Regular_13_for_values" >
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/main_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:layout_marginStart">15dp</item>
        <item name="layout_constraintHorizontal_chainStyle">packed</item>
        <item name="layout_constraintHorizontal_bias">1.0</item>
        <item name="maxLines">1</item>
        <item name="layout_constrainedWidth">true</item>
        <item name="android:ellipsize">end</item>
    </style>
    

    <style name="TextInputLayout" >
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:titleMarginTop">16dp</item>
        <item name="android:textColorHint">@color/color_AEAFB4_FFFFFFFF</item>

        <item name="boxCornerRadiusBottomEnd">5dp</item>
        <item name="boxCornerRadiusBottomStart">5dp</item>
        <item name="boxCornerRadiusTopEnd">5dp</item>
        <item name="boxCornerRadiusTopStart">5dp</item>

        <item name="boxStrokeColor">@color/grey_white_selector</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="cursorColor">@color/color_3772E7_3772E7</item>
        <item name="hintTextColor">@color/color_AEAFB4_FFFFFFFF</item>
    </style>

    <style name="TextInputEditText" >
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>

        <item name="android:imeOptions">actionDone</item>
        <item name="android:inputType">text</item>
        <item name="singleLine">true</item>

        <item name="android:maxLines">1</item>
        <item name="android:maxLength">50</item>
        <item name="android:textSize">@dimen/sp16</item>
    </style>
    
</resources>